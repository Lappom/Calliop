{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Calliop",
  "version": "0.1.0",
  "identifier": "com.calliop.app",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Calliop",
        "width": 800,
        "height": 600,
        "backgroundColor": "#000000"
      },
      {
        "label": "overlay",
        "title": "Calliop Overlay",
        "url": "overlay.html",
        "width": 300,
        "height": 88,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "visible": false,
        "skipTaskbar": true,
        "backgroundColor": "#00000000"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
