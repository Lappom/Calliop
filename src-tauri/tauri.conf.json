{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Calliop",
  "version": "0.1.0",
  "identifier": "com.calliop.app",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Calliop",
        "width": 1280,
        "height": 800,
        "minWidth": 960,
        "minHeight": 640,
        "center": true,
        "resizable": true,
        "maximized": true,
        "decorations": false,
        "backgroundColor": "#000000"
      },
      {
        "label": "overlay",
        "title": "Calliop Overlay",
        "url": "overlay.html",
        "width": 300,
        "height": 88,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "visible": false,
        "skipTaskbar": true,
        "backgroundColor": "#00000000"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "msi", "dmg", "appimage", "deb"],
    "createUpdaterArtifacts": true,
    "externalBin": ["bin/calliop-llm-worker"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "displayLanguageSelector": false,
        "installerIcon": "icons/icon.ico",
        "installMode": "currentUser"
      }
    },
    "shortDescription": "Dictée vocale locale pour toute application",
    "longDescription": "Calliop permet de dicter dans n'importe quelle application avec transcription locale Whisper et post-traitement IA optionnel. Aucune dépendance cloud pour le fonctionnement core."
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/Lappom/Calliop/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEM4QTkwOUMwMzZEM0RBOUYKUldTZjJ0TTJ3QW1weUR3S01DeHlYM2NSY0piSmJjY01DYWd2VTF3bzhqNzNzd0gwVjRoWW80cDUK"
    }
  }
}
